# Скопируй этот файл в .env и заполни своими ключами.
# .env в git НЕ попадает (см. .gitignore).

# Какой бэкенд LLM использовать: yandex | gigachat
LLM_BACKEND=yandex

# --- Yandex AI Studio (основной, выдан оргами) ---
YC_API_KEY=
YC_FOLDER=
YANDEX_MODEL=yandexgpt-lite

# --- GigaChat (запасной) ---
GIGACHAT_CREDENTIALS=

# Путь к данным
DATA_RAW=data/raw
DATA_PROCESSED=data/processed

# --- Frontend (Vite) ---
# Использовать мок-данные вместо реального API
VITE_USE_MOCK=true
# Базовый URL API (проксируется через Vite на localhost:8000)
VITE_API_URL=/api
