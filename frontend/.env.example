# Базовый URL API (без завершающего слэша).
# Dev: Vite проксирует /api → бэкенд (см. VITE_API_PROXY_TARGET).
VITE_API_URL=/api

# Куда проксировать /api в dev-режиме (только vite dev, не попадает в сборку).
VITE_API_PROXY_TARGET=http://localhost:8000

# Production: полный URL бэкенда, префикс /api не нужен.
# VITE_API_URL=https://api.example.com

# true — ответы из mock, без запросов к серверу.
VITE_USE_MOCK=false
