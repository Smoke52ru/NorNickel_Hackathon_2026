{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "vite"
    },
    "backend": {
      "root": ".",
      "framework": "fastapi",
      "entrypoint": "vercel_app:app",
      "installCommand": "pip install -r requirements-vercel.txt",
      "functions": {
        "vercel_app.py": {
          "maxDuration": 30
        }
      }
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": { "service": "backend" } },
    { "source": "/(.*)", "destination": { "service": "frontend" } }
  ]
}
